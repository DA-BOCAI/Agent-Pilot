{
  "openapi": "3.0.1",
  "info": {
    "title": "AgentCopilot 任务编排接口文档",
    "description": "用于飞书赛题的任务创建、规划、执行、确认与事件追踪",
    "version": "v1.0",
    "contact": {
      "name": "AgentCopilot 开发组"
    }
  },
  "tags": [
    {
      "name": "任务编排接口"
    },
    {
      "name": "文档与PPT预览接口"
    }
  ],
  "paths": {
    "/api/v1/tasks": {
      "post": {
        "summary": "创建任务",
        "deprecated": false,
        "description": "根据输入文本创建一个任务实例",
        "operationId": "createTask",
        "tags": [
          "任务编排接口"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateTaskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TaskView"
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/api/v1/tasks/{taskId}/plan": {
      "post": {
        "summary": "生成规划",
        "deprecated": false,
        "description": "为指定任务生成可执行步骤清单",
        "operationId": "planTask",
        "tags": [
          "任务编排接口"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "description": "",
            "required": true,
            "example": "",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TaskView"
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/api/v1/tasks/{taskId}/execute": {
      "post": {
        "summary": "执行任务",
        "deprecated": false,
        "description": "从当前进度继续执行，直到完成或遇到下一个确认闸门",
        "operationId": "executeTask",
        "tags": [
          "任务编排接口"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "description": "",
            "required": true,
            "example": "",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TaskView"
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/api/v1/tasks/{taskId}/confirm": {
      "post": {
        "summary": "确认步骤",
        "deprecated": false,
        "description": "对需要人工确认的步骤进行通过或拒绝",
        "operationId": "confirmTask",
        "tags": [
          "任务编排接口"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "description": "",
            "required": true,
            "example": "",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ConfirmTaskRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TaskView"
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/api/v1/tasks/{taskId}": {
      "get": {
        "summary": "查询任务详情",
        "deprecated": false,
        "description": "返回任务状态、步骤、产物和事件信息",
        "operationId": "getTask",
        "tags": [
          "任务编排接口"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "description": "",
            "required": true,
            "example": "",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/TaskView"
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/api/v1/tasks/{taskId}/events": {
      "get": {
        "summary": "查询任务事件",
        "deprecated": false,
        "description": "返回任务执行过程中的完整事件时间线",
        "operationId": "getEvents",
        "tags": [
          "任务编排接口"
        ],
        "parameters": [
          {
            "name": "taskId",
            "in": "path",
            "description": "",
            "required": true,
            "example": "",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TaskEvent"
                  }
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/api/v1/previews/presentation": {
      "post": {
        "summary": "预览PPT",
        "deprecated": false,
        "description": "根据用户输入生成PPT预览 JSON，按页返回 slide 结构",
        "operationId": "previewPresentation",
        "tags": [
          "文档与PPT预览接口"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PresentationPreviewRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PresentationPreviewResponse"
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    },
    "/api/v1/previews/document": {
      "post": {
        "summary": "预览文档",
        "deprecated": false,
        "description": "根据用户输入生成文档预览 JSON，包含 rawMarkdown、目录和章节结构",
        "operationId": "previewDocument",
        "tags": [
          "文档与PPT预览接口"
        ],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DocumentPreviewRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentPreviewResponse"
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "schemas": {
      "CreateTaskRequest": {
        "required": [
          "inputText",
          "requestId",
          "userId"
        ],
        "type": "object",
        "properties": {
          "inputText": {
            "type": "string",
            "description": "用户输入的任务文本",
            "example": "请帮我写一篇关于人工智能的文章，要求1000字以上，结构清晰，内容翔实。"
          },
          "source": {
            "type": "string",
            "description": "请求来源",
            "example": "im_text"
          },
          "userId": {
            "type": "string",
            "description": "发起任务用户ID",
            "example": "u-01"
          },
          "requestId": {
            "type": "string",
            "description": "请求幂等ID",
            "example": "req-2001"
          }
        }
      },
      "Artifact": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      },
      "PlanStep": {
        "type": "object",
        "properties": {
          "stepId": {
            "type": "string"
          },
          "scene": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "tool": {
            "type": "string"
          },
          "requiresConfirm": {
            "type": "boolean"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "WAIT_CONFIRM",
              "APPROVED",
              "RUNNING",
              "DONE",
              "SKIPPED",
              "FAILED"
            ]
          }
        }
      },
      "TaskEvent": {
        "type": "object",
        "properties": {
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "type": {
            "type": "string"
          },
          "message": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": {
              "type": "string"
            },
            "properties": {}
          }
        }
      },
      "TaskView": {
        "type": "object",
        "properties": {
          "taskId": {
            "type": "string"
          },
          "requestId": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "inputText": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "CREATED",
              "PLANNED",
              "WAIT_CONFIRM",
              "RUNNING",
              "DELIVERED",
              "FAILED"
            ]
          },
          "nextAction": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          },
          "planSteps": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PlanStep"
            }
          },
          "artifacts": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Artifact"
            }
          },
          "events": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TaskEvent"
            }
          }
        }
      },
      "ConfirmTaskRequest": {
        "required": [
          "approved",
          "stepId"
        ],
        "type": "object",
        "properties": {
          "stepId": {
            "type": "string",
            "description": "需要确认的步骤编号",
            "example": "C_DOC"
          },
          "approved": {
            "type": "boolean",
            "description": "是否通过该步骤",
            "example": true
          },
          "comment": {
            "type": "string",
            "description": "确认备注",
            "example": "同意执行该步骤，理由是..."
          }
        }
      },
      "PresentationPreviewRequest": {
        "required": [
          "topic",
          "userInput"
        ],
        "type": "object",
        "properties": {
          "userInput": {
            "type": "string",
            "title": "用户原始需求描述"
          },
          "topic": {
            "type": "string",
            "title": "PPT主题",
            "description": "示例：\"2026年双十一营销活动汇报"
          }
        }
      },
      "PresentationPreviewResponse": {
        "type": "object",
        "properties": {
          "artifactType": {
            "type": "string",
            "title": "产物类型",
            "description": "固定为“presentation”"
          },
          "title": {
            "type": "string",
            "title": "PPT标题"
          },
          "rawMarkdown": {
            "type": "string",
            "title": "原始Markdown完整内容",
            "description": "用户编辑、同步到飞书都用这个字段"
          },
          "generatedAt": {
            "type": "string",
            "title": "生成时间",
            "description": "ISO格式"
          },
          "pageCount": {
            "type": "integer",
            "format": "int32",
            "title": "PPT总页数"
          },
          "slides": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Slide"
            },
            "title": "逐页内容",
            "description": "用于前端模拟PPT翻页预览"
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "title": "警告信息",
            "description": "没有则为空数组"
          }
        }
      },
      "Slide": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "title": "页面唯一ID"
          },
          "slideNo": {
            "type": "integer",
            "format": "int32",
            "title": "页码",
            "description": "从1开始"
          },
          "title": {
            "type": "string",
            "title": "页面标题",
            "description": "对应Markdown的## 标题"
          },
          "bodyMarkdown": {
            "type": "string",
            "title": "页面完整的Markdown内容"
          },
          "bullets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "title": "页面要点列表",
            "description": "用于缩略图预览展示"
          }
        }
      },
      "DocumentPreviewRequest": {
        "required": [
          "docType",
          "userInput"
        ],
        "type": "object",
        "properties": {
          "userInput": {
            "type": "string",
            "title": "用户原始需求描述"
          },
          "docType": {
            "type": "string",
            "title": "文档类型",
            "description": "可选值：需求文档、营销方案、技术方案、调研报告、活动策划等"
          }
        }
      },
      "Block": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "title": "内容块唯一ID"
          },
          "type": {
            "type": "string",
            "title": "块类型",
            "description": "text=普通段落、list=列表、table=表格、heading=标题"
          },
          "text": {
            "type": "string",
            "title": "文本内容",
            "description": "仅对text类型有效，其他类型为空"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "title": "列表项内容",
            "description": "仅对list类型有效，其他类型为空"
          }
        }
      },
      "DocumentPreviewResponse": {
        "type": "object",
        "properties": {
          "artifactType": {
            "type": "string",
            "title": "产物类型",
            "description": "固定为“document”"
          },
          "title": {
            "type": "string",
            "title": "文档标题",
            "description": "自动根据用户需求生成"
          },
          "rawMarkdown": {
            "type": "string",
            "title": "原始Markdown完整内容",
            "description": "用户编辑、同步到飞书都用这个字段"
          },
          "generatedAt": {
            "type": "string",
            "title": "生成时间",
            "description": "ISO格式，示例：\"2026-04-27T18:30:00+08:00"
          },
          "outline": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OutlineItem"
            },
            "title": "文档目录",
            "description": "用于前端渲染侧边栏导航"
          },
          "sections": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Section"
            },
            "title": "分章节内容",
            "description": "用于前端分段渲染、区块编辑"
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "title": "警告信息",
            "description": "比如内容过长、敏感词提示等，没有则为空数组"
          }
        }
      },
      "OutlineItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "title": "目录项唯一ID",
            "description": "用于锚点跳转"
          },
          "level": {
            "type": "integer",
            "format": "int32",
            "title": "标题层级",
            "description": "1=一级标题，2=二级标题，3=三级标题"
          },
          "title": {
            "type": "string",
            "title": "标题文本"
          }
        }
      },
      "Section": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "title": "章节ID"
          },
          "level": {
            "type": "integer",
            "format": "int32",
            "title": "章节层级"
          },
          "title": {
            "type": "string",
            "title": "章节标题"
          },
          "blocks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Block"
            },
            "title": "章节内容块",
            "description": "支持文本、列表、表格等类型"
          }
        }
      }
    },
    "responses": {},
    "securitySchemes": {}
  },
  "servers": [],
  "security": []
}